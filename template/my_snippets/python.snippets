snippet argparse "Parse argument in"
from sys import argv as sys_argv   # Help argparse detect no argument
from argparse import ArgumentParser, RawTextHelpFormatter  # Parse input arguments

parser = ArgumentParser(description=__doc__, formatter_class=RawTextHelpFormatter)

# Positional
parser.add_argument('positional', type=str, help='A positional argument')

# Flag
parser.add_argument('--test', action='store_true', help='Run non regression test')

# String 1
parser.add_argument('-o', '--optional', type=str, default='default_value', help='An optional argument')

# Create rut
parser.add_argument('--generate-rut', nargs=2, help='Generate Rutn from <rut1: int> to <rut2: int>')

# Clause: Leave now if no argument
if not sys_argv[1:]:
		return parser, parser.parse_args(['--help'])

# Parse arguments from Stdin
args = parser.parse_args(args=None)
endsnippet

