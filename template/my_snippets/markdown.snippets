snippet code "Change code size"
\slide{\DefineVerbatimEnvironment{Highlighting}{Verbatim}{breaklines,commandchars=\\\\\\{\\},fontsize=\fontsize{12}{11}\selectfont}}
endsnippet

snippet high "Change code size"
\slide{\DefineVerbatimEnvironment{Highlighting}{Verbatim}{breaklines,commandchars=\\\\\\{\\},fontsize=\fontsize{12}{11}\selectfont}}
endsnippet

