endsnippet

snippet off "Turn miniframe off"
\`\`\`{=latex}
\end{frame}
\miniframesoff
\begin{frame}<0| handout:0>
\`\`\`
endsnippet

snippet on "Turn miniframe on"
\`\`\`{=latex}
\end{frame}
\miniframeson
\begin{frame}<0| handout:0>
\`\`\`
endsnippet

snippet off2 "Turn miniframe off"
\`\`\`{=latex}
\book{\begin{frame}}
\end{frame}
\miniframesoff
\slide{\begin{frame}<0| handout:0>}
\`\`\`
endsnippet

snippet on2 "Turn miniframe on"
\`\`\`{=latex}
\book{\begin{frame}}
\end{frame}
\miniframeson
\slide{\begin{frame}<0| handout:0>}
\`\`\`
endsnippet

snippet fn "Footnote"
\renewcommand{\myfootnote}{\footnote{}}
\book{\protect\myfootnote}
\slide{\myfootnote}
endsnippet

snippet wf "WrapFig"
\book{\begin{wrapfigure}{Rt}{5cm}}
\book{\end{wrapfigure}}
endsnippet

snippet mp "minipage"
\`\`\`{=latex}
