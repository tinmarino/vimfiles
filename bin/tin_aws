  run rsync -avz \
    -e 'ssh -i /home/mtourneboeuf/Secret/aws-ciberlab-dreamlab.pem -o StrictHostKeyChecking=no' \
    --exclude='.git/' \
    ~/Software/Pentest/libreriactf/ \
    ubuntu@crat.tinmarino.com:/data/libreriactf/
}

