#!/usr/bin/env bash
set -u

# Call vim with arguments
call_vim(){
  # Use --cmd because it is done before first file read
    #-cmd 'silent! autocmd StdinReadPre * set nomodeline'
  a_shell_vim=(
    vim
    -c "silent! MANPAGER"
    -c "map q :q!<CR>"
    -c "set foldlevel=30"
    -c "set nonumber"
    -c "set t_te="
    -c "silent! nnoremap n nzt<C-y><C-y>"
    -c "silent! /^\(\e\[\d*m\)*--- a\/.*$/"
    -c "silent! autocmd StdinReadPre * set nomodeline"
    -c 'silent! autocmd StdinReadPre * set nomodeline'
    "$@"
  )
  "${a_shell_vim[@]}"
}

if ! (return 0 2>/dev/null); then
  if (($# < 1)) || [[ -z "$1" ]]; then
    call_vim -
  else
    man "$@" | call_vim -
  fi
  exit "$?"
fi
