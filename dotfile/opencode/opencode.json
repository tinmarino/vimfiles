{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",

    "read":  {
      "*": "allow",
      "*.env": "deny",
      "*secret*": "deny",
      "**/.ssh/**": "deny"
    },
    "edit":  "allow",

    "bash": {
      "*": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "git add *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git commit *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "pylint *": "allow",
      "pytest *": "allow",
      "make *": "allow",
      "docker compose exec *": "allow",
      "mkdir -p *": "allow",
      "mv /tmp/* *": "allow",
      "node *": "allow",

      "rm -rf *": "deny",
      "sudo rm *": "deny",
      "#git push *": "deny",
      "#git push --force*": "deny"
    },

    "external_directory": {
      "/tmp/**": "allow"
    }
  }
}
